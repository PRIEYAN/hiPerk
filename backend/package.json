{
  "name": "hiperk-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "hiPerk orchestration backend: proof requests, x402 metering, Soroban + fee-bump relayer",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "@x402/core": "^2.17.0",
    "@x402/express": "^2.17.0",
    "@x402/stellar": "^2.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
