# --- Network ---
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# --- Contracts (fill in from blockchain/scripts/deploy.sh output) ---
GATEKEEPER_CONTRACT_ID=
PERK_CONTRACT_ID=

# --- Keys ---
# Relayer secret seed (S...). Sponsors all fee-bump txns and is the trusted
# caller for register_member / claim. NEVER expose to the frontend.
RELAYER_SECRET_KEY=
ADMIN_PUBLIC_KEY=

# Token (SAC) address used for payouts, e.g. testnet USDC. Optional for mock mode.
PAYOUT_TOKEN_ID=

# --- Modes ---
# mock: no real proving / no on-chain submission (runs fully offline for demos).
# live: requires the contract IDs + relayer key above to be set.
PROVER_MODE=mock        # mock | boundless (boundless calls the prover/ Rust service below)
X402_MODE=mock          # mock | live   (live also requires facilitator+payTo below)
CHAIN_MODE=auto         # auto | mock | live   (auto = live iff contracts+key set)

# --- RISC Zero prover service (prover/host) ---
# Only used when PROVER_MODE=boundless. See prover/README.md for setup.
PROVER_SERVICE_URL=http://localhost:8080

# --- x402 payment gate on POST /claims ---
# Built-on-Stellar (or any x402-compatible) facilitator that verifies/settles
# the USDC micropayment on Stellar testnet. Leave blank to stay in mock mode.
X402_FACILITATOR_URL=
X402_NETWORK=stellar:testnet
# Stellar G... address that receives the micropayment (e.g. relayer's address).
X402_PAY_TO=
# USDC SAC contract id on the target network. Defaults to the scheme's
# built-in USDC address if left blank.
X402_USDC_CONTRACT_ID=
# Price per claim submission, in USD (e.g. "0.001").
X402_PRICE_USD=0.001

# Default reward (base units) granted per approved claim when none specified.
DEFAULT_REWARD_AMOUNT=400

PORT=4000
CORS_ORIGIN=http://localhost:3000
